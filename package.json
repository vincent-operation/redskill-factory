{
  "name": "redskill-factory",
  "version": "0.1.0",
  "description": "小红书技能工厂 — 快速制作、测试、打包可在 RedSkill 商店分发的 AI 技能",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rfs": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "eslint src/ tests/",
    "clean": "node --input-type=module -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true})\"",
    "server:dev": "tsx watch src/server/index.ts",
    "server:start": "node dist/server/index.js",
    "web:dev": "cd web && npx vite",
    "web:build": "cd web && npx vite build",
    "dev:all": "concurrently -n server,web -c blue,green \"npm run server:dev\" \"npm run web:dev\"",
    "build:all": "npm run build && npm run web:build"
  },
  "keywords": [
    "xiaohongshu",
    "redskill",
    "ai-skill",
    "skill-factory",
    "monetization"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "mustache": "^4.2.0",
    "ora": "^8.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mustache": "^4.2.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
