# RedSkill Factory — Environment Configuration
# Copy this file to .env and fill in your keys

# Server
RFS_SERVER_PORT=3001

# DeepSeek API (OpenAI-compatible) — REQUIRED for LLM features
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic Claude API (optional, via DeepSeek compatible endpoint or direct)
ANTHROPIC_AUTH_TOKEN=your-token-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ─── Payment ────────────────────────────────────
# 支付系统: 留空使用个人收款码模式 (无需商户号，立即可用)
# 填入真实商户号后自动切换为 API 模式

# Server public URL (for payment callbacks)
RFS_SERVER_URL=http://localhost:3001

# WeChat Pay V3 (API mode — optional)
# WECHAT_APP_ID=wxXXXXXXXX
# WECHAT_MCH_ID=1234567890
# WECHAT_API_KEY_V3=your-api-v3-key

# Alipay Open Platform (API mode — optional)
# ALIPAY_APP_ID=2021XXXXXXXX
# ALIPAY_PRIVATE_KEY=your-rsa-private-key
# ALIPAY_PUBLIC_KEY=alipay-public-key
